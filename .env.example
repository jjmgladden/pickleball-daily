# Pickleball Daily Intelligence — Environment Template
# Copy this file to .env (which is gitignored) and fill in real values.
# NEVER commit the populated .env file.

# YouTube Data API v3 — required for highlight ingestion (Phase 1+).
# Shared with sibling Baseball Project (same Google Cloud project + key).
# Restrict the key to YouTube Data API v3.
# Get at: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=

# Resend email (Phase 3C) — shared account with sibling project per KB-0007.
# Get key at: https://resend.com → API Keys
# RESEND_API_KEY=re_...
# EMAIL_RECIPIENTS=you@example.com,reader@example.com
# EMAIL_FROM="Ozark Joe's Pickleball Daily <onboarding@resend.dev>"   # optional override
# EMAIL_DRY_RUN=1                                                       # local preview without sending

# DUPR per-player access (Phase 2, optional)
# DUPR_USERNAME=
# DUPR_PASSWORD=
